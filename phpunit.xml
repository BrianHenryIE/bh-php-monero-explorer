<?xml version="1.0" encoding="UTF-8"?>
<!--
  Test suites:
   - unit:     no network access; runs by default (`composer test`).
   - contract: LIVE calls to xmrchain.net (requires `.env.secret`); excluded from
               CI. To be replaced by deterministic Docker-backed integration
               suites — see MODERNIZATION_AND_INTEGRATION_TEST_PLAN.md.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.0/phpunit.xsd" backupGlobals="false" colors="true" bootstrap="vendor/autoload.php" defaultTestSuite="unit" beStrictAboutTestsThatDoNotTestAnything="true" beStrictAboutOutputDuringTests="true" beStrictAboutChangesToGlobalState="true">
  <coverage/>
  <testsuites>
    <testsuite name="unit">
      <directory>tests/unit</directory>
    </testsuite>
    <testsuite name="contract">
      <directory>tests/contract</directory>
    </testsuite>
  </testsuites>
  <source>
    <include>
      <directory>src</directory>
    </include>
  </source>
</phpunit>
